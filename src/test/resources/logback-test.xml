<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true">

    <!-- ========================================================= -->
    <!-- MDC variable for per-test logging                         -->
    <!-- ========================================================= -->
    <variable name="TEST_NAME" value="${mdc:testName:-unknown-test}" />

    <!-- ========================================================= -->
    <!-- Pattern (aligned for step numbers + durations)            -->
    <!-- ========================================================= -->
    <property name="LOG_PATTERN"
              value="%d{HH:mm:ss.SSS} %-5level [%thread] [%X{testName:-no-test}] %logger{36} - %msg%n" />

    <!-- ========================================================= -->
    <!-- Console Appender                                          -->
    <!-- ========================================================= -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ========================================================= -->
    <!-- Global Framework Log (Rolling)                            -->
    <!-- ========================================================= -->
    <appender name="FRAMEWORK" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/framework.log</file>

        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/framework.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>

        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ========================================================= -->
    <!-- Per-Test Log File (MDC-driven)                            -->
    <!-- ========================================================= -->
    <appender name="PER_TEST" class="ch.qos.logback.core.FileAppender">
        <file>logs/${TEST_NAME}.log</file>
        <append>true</append>

        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ========================================================= -->
    <!-- Root Logger                                               -->
    <!-- ========================================================= -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FRAMEWORK" />
        <appender-ref ref="PER_TEST" />
    </root>

</configuration>